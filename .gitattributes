# Normaliza todos los archivos de texto a LF en el repo (evita los warnings
# LF↔CRLF en Windows). Git detecta qué es texto y guarda siempre con LF.
* text=auto eol=lf

# Binarios: nunca tocar los saltos de línea.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.pdf binary
